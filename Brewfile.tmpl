# Brewfile — declarative machine package manifest (chezmoi template).
# Rendered in bootstrap.sh via `chezmoi execute-template` and fed to `brew bundle`.
# Not deployed to $HOME (see .chezmoiignore) — consumed operationally.
# Install:   chezmoi execute-template < Brewfile.tmpl | brew bundle --file=/dev/stdin
# Snapshot:  brew bundle dump --force --describe --file=Brewfile   (then port into .tmpl)
#
# Per-machine: blocks under `if eq .profile "..."` are installed only on machines
# with the matching profile (set once at `chezmoi init`, see .chezmoi.toml.tmpl).

# CLI tools — via mise (mise-first), see ~/.config/mise/config.toml.
# Brewfile holds only GUI casks and formulae that mise can't provide.

# === CLI formulae mise can't provide — all machines ===
brew "sshpass" # non-interactive ssh password auth (used by ansible) — not in mise registry
brew "libpq"   # PostgreSQL client only (psql, pg_dump, …) without the server — mise's postgres builds the full server; keg-only, PATH added in .zshrc
brew "skopeo"  # inspect/copy/sign OCI & container images without a daemon — not in mise registry
brew "unar"    # universal unarchiver (rar, 7z, …) — not in mise registry
brew "mas"     # Mac App Store CLI — declares/installs the App Store apps listed below; not in mise

# === GUI apps (casks) — all machines ===
cask "visual-studio-code" # primary editor (self-updating; cask is auto_updates, brew won't fight it)
cask "zed"                # Zed — fast multiplayer code editor (self-updating cask, auto_updates)
cask "obsidian"           # Markdown knowledge base / vault editor (hypomnemata exocortex; self-updating cask, auto_updates)
cask "freelens"           # Kubernetes IDE (open-source Lens fork)
cask "cmux"               # Ghostty-based terminal with vertical tabs + notifications for AI coding agents
cask "wakatime"           # Menu-bar time tracker — whole-system activity beyond editor plugins
cask "pearcleaner"        # app uninstaller + orphaned-file finder (open-source CleanMyMac alt)
cask "docker-desktop"     # Docker Desktop — container engine + CLI + VM (launch once to start the daemon)
cask "yandex-music"       # Yandex Music desktop player (self-updating cask)

# === Work machine only (profile = work) ===
{{ if eq (dig "profile" "personal" .) "work" -}}
cask "dotnet-sdk"  # .NET SDK — needed on the work machine only
cask "windows-app" # Microsoft's official RDP client (formerly Remote Desktop; microsoft-remote-desktop discontinued 2025-10) — connect to Windows over RDP
{{- end }}

# === Mac App Store apps (mas) — real machines only ===
# Skipped in CI: the macOS runner is not signed into the App Store, so `mas install`
# (bootstrap) and `brew bundle check` (smoke) would fail on these entries. A real
# machine needs a one-time App Store sign-in before bootstrap — the only step here
# that cannot live in code.
{{ if not (env "CI") -}}
mas "one sec", id: 1532875441     # delay distracting apps — digital-hygiene gate (pause before Telegram/feeds)
mas "Bitwarden", id: 1352778147   # password manager
mas "Focus To-Do", id: 1258530160 # Pomodoro + time tracking — core to the self-development practice
mas "WireGuard", id: 1451685025   # WireGuard VPN client
mas "v2RayTun", id: 6476628951    # V2Ray / proxy client
mas "Endel", id: 1346247457       # adaptive focus/sleep soundscapes
mas "MKPlayer", id: 1335612105    # media player
{{- end }}
