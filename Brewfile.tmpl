# Brewfile — declarative machine package manifest (chezmoi template).
# Rendered in bootstrap.sh via `chezmoi execute-template` and fed to `brew bundle`.
# Not deployed to $HOME (see .chezmoiignore) — consumed operationally.
# Install:   chezmoi execute-template < Brewfile.tmpl | brew bundle --file=/dev/stdin
# Snapshot:  brew bundle dump --force --describe --file=Brewfile   (then port into .tmpl)
#
# Per-machine: blocks under `if eq .profile "..."` are installed only on machines
# with the matching profile (set once at `chezmoi init`, see .chezmoi.toml.tmpl).

# CLI tools — via mise (mise-first), see ~/.config/mise/config.toml.
# Brewfile holds only GUI casks and formulae that mise can't provide.

# === CLI formulae mise can't provide — all machines ===
brew "sshpass" # non-interactive ssh password auth (used by ansible) — not in mise registry

# === GUI apps (casks) — all machines ===
cask "visual-studio-code" # primary editor (self-updating; cask is auto_updates, brew won't fight it)
cask "freelens"           # Kubernetes IDE (open-source Lens fork)
cask "wakatime"           # Menu-bar time tracker — whole-system activity beyond editor plugins
cask "pearcleaner"        # app uninstaller + orphaned-file finder (open-source CleanMyMac alt)
cask "docker-desktop"     # Docker Desktop — container engine + CLI + VM (launch once to start the daemon)
cask "yandex-music"       # Yandex Music desktop player (self-updating cask)

# === Work machine only (profile = work) ===
{{ if eq (dig "profile" "personal" .) "work" -}}
cask "dotnet-sdk" # .NET SDK — needed on the work machine only
{{- end }}
