# Managed by chezmoi (source: dot_zshrc.tmpl).

# --- Homebrew (Apple Silicon → /opt/homebrew, Intel → /usr/local) ---
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# libpq (PostgreSQL client) is keg-only → brew won't symlink psql into PATH; add it here.
if [ -d "$(brew --prefix 2>/dev/null)/opt/libpq/bin" ]; then
  export PATH="$(brew --prefix)/opt/libpq/bin:$PATH"
fi

# --- Ansible fork-safety on macOS ---
# macOS' Objective-C runtime forbids fork() after an ObjC class has begun initializing
# in another thread; Ansible forks worker processes and crashes with
# "+[NSCharacterSet initialize] may have been in progress ... Crashing instead".
# This opt-out restores the pre-High-Sierra fork behavior so Ansible runs cleanly.
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# --- Resource limits ---
# macOS GUI-launched terminals (cmux/Ghostty from /Applications) inherit launchd's low
# RLIMIT_NOFILE soft limit (256). fd-hungry workloads + zsh-autocomplete's zpty async (see
# below) blow past it → "_zsh_highlight: cannot duplicate fd 1: too many open files". Raise
# toward the per-process kernel cap (kern.maxfilesperproc=61440); only ever raises.
(( $(ulimit -Sn) < 49152 )) && ulimit -Sn 49152

# --- Oh My Zsh (plugins only; Starship draws the prompt) ---
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""                       # theme off — prompt handed to Starship
plugins=(
  # tool integrations (aliases + completion)
  git
  kubectl
  helm
  terraform
  aws
  ansible
  gh
  # productivity (built-in)
  colored-man-pages               # colored man pages
  extract                         # `x <archive>` — extract anything
  sudo                            # double-Esc → prepend sudo
  copypath                        # copy $PWD to clipboard
  copybuffer                      # Ctrl-O → copy current command line
  dirhistory                      # Alt+←/→ dir history, Alt+↑ parent
  forgit                          # fzf-powered git (ga/glo/gd)
  zsh-completions                 # extra completion definitions
  # line editing — order matters; autocomplete LAST so its keybindings win
  zsh-autosuggestions
  zsh-you-should-use              # nag when a typed command has an alias
  zsh-syntax-highlighting
  zsh-autocomplete                # live menu completion
)

# zsh-autocomplete's async completion runs in a zsh/zpty subshell that Ghostty/cmux fails to
# reap, leaking ~16KB pipe pairs per completion until the fd ceiling is hit (observed: panes
# holding 1300+ pipes). Disable async → live menu stays, completion is synchronous, no zpty.
# Must be set BEFORE oh-my-zsh sources the plugin.
zstyle ':autocomplete:*' async no

source "$ZSH/oh-my-zsh.sh"

# zsh-you-should-use registers three preexec hooks; its global-alias check runs
# `alias -g | sort | ...`, which zsh-autocomplete's job-control rewrite turns into a
# stray background job that fails and prints `[1] done ... exit 2 sort` after every
# command. Drop only that hook — the regular and git-alias nags keep working.
add-zsh-hook -d preexec _check_global_aliases

# --- mise: activate after compinit (from oh-my-zsh) ---
eval "$("$HOME/.local/bin/mise" activate zsh)"

# --- fzf ---
eval "$(fzf --zsh)"

# --- Starship prompt (last, draws the prompt) ---
eval "$(starship init zsh)"

# --- Helpers ---
# `mise use -g` / `mise unuse -g` write to the target (~/.config/mise/config.toml), but
# chezmoi does not update the source itself → the next `chezmoi apply` would revert it.
# miseg/miserm re-add the source right after the change, so drift doesn't accumulate.
miseg()  { mise use   -g "$@" && chezmoi add ~/.config/mise/config.toml; }   # add a tool
# miserm also uninstalls the binary. External backend caches (rustup's ~/.rustup,
# cargo's ~/.cargo, …) are NOT cleaned — purge those by hand if a backend leaves them.
miserm() { mise unuse -g "$@" && mise uninstall "$@" 2>/dev/null; chezmoi add ~/.config/mise/config.toml; }   # remove a tool
# brew has no miseg-style auto-sync: Brewfile.tmpl is a curated chezmoi template (per-machine
# `if profile` + a description per line), so `brew bundle dump` can't be snapshotted back without
# erasing that structure. brewdiff instead just reports drift vs the rendered manifest — port new
# packages into Brewfile.tmpl by hand (with a `# desc`, into the right profile block).
brewdiff() {
  local f; f="$(mktemp)"
  chezmoi execute-template < "$(chezmoi source-path)/Brewfile.tmpl" > "$f" || { rm -f "$f"; return 1; }
  print -P "%F{yellow}── in Brewfile, not installed ──%f"
  brew bundle check --file="$f" --verbose
  print -P "%F{yellow}── installed, NOT in Brewfile (drift) ──%f"
  brew bundle cleanup --file="$f"   # dry-run list; `brew bundle cleanup --force --file=…` removes them
  rm -f "$f"
}

# --- Aliases: kubectl extras (the omz `kubectl` plugin provides k/kl/kgp/kgaa/...) ---
# Only what the plugin lacks. Note: plugin's `kga` = `get all`, all-namespaces = `kgaa`.
alias kg="kubectl get"             # plain get
alias kgy="kubectl get -o yaml"    # get as yaml
alias kd="kubectl describe"        # describe (plugin only has kdp/kds)
alias kctx="kubectx"               # context switch (separate tool)

# --- terragrunt: alias + completion (omz `terraform` plugin covers tf*; terragrunt has none) ---
# terragrunt v1.x CLI ships no completion script and ignores --generate-shell-completion, but
# its binary answers COMP_LINE/COMP_POINT (posener-style) → drive it via bash-style `complete -C`.
# bashcompinit must run after compinit (loaded by oh-my-zsh.sh above).
alias tg="terragrunt"
# Silence terragrunt's own wrapper logging (the `time=… level=… msg=…` lines) so only
# the underlying OpenTofu/Terraform output shows. Per-command override: TG_LOG_DISABLE=false tg ...
export TG_LOG_DISABLE=true
autoload -U +X bashcompinit && bashcompinit
complete -o nospace -C terragrunt terragrunt
compdef tg=terragrunt   # the tg alias inherits terragrunt's completion

# --- Aliases: modern CLI replacements (mise-managed) ---
alias cat="bat"    # syntax highlighting + paging
alias du="dust"    # disk usage, visual tree
alias df="duf"     # disk free, tabular

# eza (modern ls): shared flags once, then per-view aliases
eza_params=('--git' '--group' '--group-directories-first')
alias ls='eza $eza_params'
alias ll='eza --long $eza_params'
alias la='eza --long --all $eza_params'
alias lal='eza -lbhHigUmuSa'
alias tree='eza --tree $eza_params'

# --- chezmoi sync ---
# .zshrc is a TEMPLATE: edit the source (dot_zshrc.tmpl) and apply;
# NEVER `chezmoi add ~/.zshrc` (it destroys template directives, e.g. secrets).
alias cza='chezmoi apply'    # source → live (e.g.: cza ~/.zshrc)
alias czu='chezmoi update'   # git pull + apply (pull from another machine)
alias czd='chezmoi diff'     # show source ↔ live drift

# --- git: always sign off commits ---
# oh-my-zsh's git plugin commit shortcuts call `git commit` directly, bypassing
# the `ci = commit -s` git alias. Re-define the ones we actually use so they add
# a Signed-off-by trailer. A shell-level override (not a git hook) keeps the
# pre-commit framework working.
alias gc='git commit --verbose --signoff'
alias gca='git commit --verbose --all --signoff'
alias gcam='git commit --all --signoff --message'
alias gcmsg='git commit --signoff --message'
alias 'gc!'='git commit --verbose --signoff --amend'
alias 'gca!'='git commit --verbose --all --signoff --amend'

# --- zsh-autosuggestions tuning ---
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE="20"   # don't suggest for very long buffers
ZSH_AUTOSUGGEST_USE_ASYNC=1            # compute suggestions in the background

# --- zoxide (replaces cd with frecency jumping; `cdi` = interactive picker) ---
# has to be the last to override cd (after oh-my-zsh and plugins)
# zoxide's "doctor" heuristic misfires in non-interactive shells that still source this file
# (tool / CI / subshells) even though init IS last here — silence it; placement above is correct.
export _ZO_DOCTOR=0
eval "$(zoxide init zsh --cmd cd)"

# --- Daily update check (mise + brew) ---
# First interactive shell of the day: print the cached summary instantly, then refresh it in
# the background. Never blocks the prompt — the network checks (slow: mise's endpoint is
# DPI-throttled abroad) run detached. Run `updates` anytime, `updates -r` to recheck now.
# Logic lives in ~/.local/bin/updates.
if [[ -o interactive ]] && (( $+commands[updates] )); then
  () {
    emulate -L zsh
    local marker="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles-updates/shown-on" today
    today="$(date +%F)"
    [[ "$(<"$marker" 2>/dev/null)" == "$today" ]] && return   # already shown today (other tabs stay quiet)
    mkdir -p "${marker:h}" && print -r -- "$today" >| "$marker"
    updates --quiet                  # show last cached summary (instant; silent if up to date)
    ( updates --bg & ) &>/dev/null    # refresh cache in the background for next time
  }
fi
