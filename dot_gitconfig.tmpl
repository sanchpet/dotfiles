# Git identity. Personal (sanchpet) is the default everywhere, with SSH commit
# signing whenever the signing key is present. Work repos under ~/IWE/magnit/
# switch to the work identity (signing off) via the includeIf at the bottom.
[user]
	name = sanchpet
	email = petrov@sanch.pet
{{- $key := joinPath .chezmoi.homeDir ".ssh/id_ed25519.pub" }}
{{- if stat $key }}
	signingkey = {{ $key }}
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
{{- end }}
[push]
	default = simple
# Default `git pull` to rebase instead of merge, so pulling a shared branch
# replays local commits on top rather than creating a merge bubble. autoStash
# lets it run with a dirty worktree (stash → rebase → pop).
[pull]
	rebase = true
[rebase]
	autoStash = true

# delta: syntax-highlighting pager for diffs (installed via mise).
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true       # use n / N to jump between diff sections
	dark = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictStyle = zdiff3

# Work repos live under ~/IWE/magnit/. Override to the work identity and turn
# signing off there; everything else stays personal and signed.
[includeIf "gitdir:~/IWE/magnit/"]
	path = ~/.config/git/work.inc
