# Git identity — per-machine via .profile (see .chezmoi.toml.tmpl).
# work → work identity, otherwise → personal. dig guards against a missing key.
[user]
{{- if eq (dig "profile" "personal" .) "work" }}
	name = petrov_ad
	email = petrov_ad@magnit.ru
{{- else }}
	name = sanchpet
	email = petrov@sanch.pet
{{- end }}
[push]
	default = simple

# delta: syntax-highlighting pager for diffs (installed via mise).
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true       # use n / N to jump between diff sections
	dark = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictStyle = zdiff3
