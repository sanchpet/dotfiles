# Brewfile — декларативный манифест пакетов machine
# Установка:   brew bundle --file=Brewfile
# Снимок:      brew bundle dump --force --describe --file=Brewfile
# Проверка:    brew bundle check --file=Brewfile
# Очистка:     brew bundle cleanup --file=Brewfile   (--force чтобы удалить)

# === CLI-инструменты (formulae) ===
brew "chezmoi" # менеджер dotfiles (раскладка конфигов + секреты + per-machine)

# === GUI-приложения (casks) ===
cask "freelens" # Kubernetes IDE (open-source форк Lens)
